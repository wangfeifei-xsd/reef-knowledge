{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "海洋知识库",
  "version": "0.1.0",
  "identifier": "com.reef.knowledge",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "海洋知识库",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../data/wiki/": "default-wiki/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "Productivity",
    "shortDescription": "「海洋知识库」：Karpathy 式知识库（原始/编译/规范三层 + LLM 编译 + 双路召回）",
    "longDescription": "「海洋知识库」是跨平台（桌面 + 移动）的本地知识库应用，将 Markdown 三层结构与 OpenAI 兼容模型协议结合，提供本地编译、Lint、对话召回等能力。"
  }
}
